# Kafka / Redpanda
KAFKA_BROKER=localhost:9092
KAFKA_GROUP_PREFIX=apartment-tracker

# TimescaleDB (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apartment_tracker

# Telegram notifications (optional — hooks no-op if not set)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set to "true" to allow Claude Code hooks to edit protected infra files
# (docker-compose.yml, .github/workflows/, .claude/)
ALLOW_INFRA_EDIT=
